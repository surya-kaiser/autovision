# ============================================================================
# AutoVision Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values as needed
#
# For Docker Compose:
#   - Copy to .env in the project root
#   - docker-compose will automatically load these variables
#
# For local development:
#   - Copy to backend/.env and frontend/.env
#   - Load manually or use a tool like python-dotenv
# ============================================================================

# ────────────────────────────────────────────────────────────────────────────
# Docker & Docker Compose Settings
# ────────────────────────────────────────────────────────────────────────────

# Docker registry for pushing images (Docker Hub: docker.io, ECR, etc.)
DOCKER_REGISTRY=docker.io

# Docker image version tag
IMAGE_TAG=latest

# Docker compose project name
COMPOSE_PROJECT_NAME=autovision

# ────────────────────────────────────────────────────────────────────────────
# Backend Configuration
# ────────────────────────────────────────────────────────────────────────────

# Backend service port (inside container: 8000)
BACKEND_PORT=8000

# Ollama LLM Service Configuration
# For Docker Compose: use service name 'ollama'
# For local development: use 'http://localhost:11434'
OLLAMA_BASE_URL=http://ollama:11434

# LLM Model to use
OLLAMA_MODEL=llama3.2

# Python environment
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Backend host binding (0.0.0.0 for Docker, 127.0.0.1 for local)
BACKEND_HOST=0.0.0.0

# ────────────────────────────────────────────────────────────────────────────
# Frontend Configuration
# ────────────────────────────────────────────────────────────────────────────

# Frontend service port (exposed port)
FRONTEND_PORT=5173

# API backend URL (used by frontend to call backend)
# For Docker Compose: use service name 'backend'
# For local development: use 'http://localhost:8000'
VITE_API_URL=http://backend:8000/api/v1

# ────────────────────────────────────────────────────────────────────────────
# Volume & Data Storage
# ────────────────────────────────────────────────────────────────────────────

# Upload directory (inside container: /tmp/autovision/uploads)
# Can be mounted as volume for persistence
UPLOAD_DIR=/tmp/autovision/uploads

# Model directory (inside container: /tmp/autovision/models)
# Can be mounted as volume for persistence
MODEL_DIR=/tmp/autovision/models

# ────────────────────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────────────────────

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log directory
LOG_DIR=/tmp/autovision/logs

# ────────────────────────────────────────────────────────────────────────────
# Jenkins CI/CD Configuration
# ────────────────────────────────────────────────────────────────────────────

# Python version for Jenkins
PYTHON_VERSION=3.11

# Node version for Jenkins
NODE_VERSION=18

# Jenkins workspace (optional)
# JENKINS_WORKSPACE=/var/jenkins_home/workspace/autovision

# ────────────────────────────────────────────────────────────────────────────
# Service Health Check Configuration
# ────────────────────────────────────────────────────────────────────────────

# Backend health check endpoint
BACKEND_HEALTH_ENDPOINT=/api/v1/system/info

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# Health check timeout (seconds)
HEALTH_CHECK_TIMEOUT=10

# ────────────────────────────────────────────────────────────────────────────
# Debugging & Development
# ────────────────────────────────────────────────────────────────────────────

# Enable debug mode (not recommended for production)
DEBUG=false

# Enable hot reload (for development)
VITE_DEV_HOT_RELOAD=true

# ────────────────────────────────────────────────────────────────────────────
# GPU Support (optional)
# ────────────────────────────────────────────────────────────────────────────

# Enable GPU support for PyTorch (if available)
# Uncomment and set to 1 to enable
# CUDA_VISIBLE_DEVICES=0

# Enable Ollama GPU support
# Uncomment to enable (requires Ollama image with GPU support)
# OLLAMA_GPU=1
